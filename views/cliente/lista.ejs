<script src="/js/cliente/lista.js"></script>

<div class="page-card">

    <div class="page-header">
        <h1>Clientes cadastrados</h1>

        <a class="btn btn-primary" href="/cliente/cadastrar">
            <i class="fas fa-plus"></i> Cadastrar Cliente
        </a>
    </div>

    <div class="table-responsive tabela-scroll">
        <table class="table table-striped table-hover align-middle tabela-sistema">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>CPF</th>
                    <th>Nascimento</th>
                    <th>Gênero</th>
                    <th>Telefone</th>
                    <th>E-mail</th>
                    <th>Ativo</th>
                    <th>Ações</th>
                </tr>
            </thead>

            <tbody>
                <% for(let i = 0; i < lista.length; i++) { %>
                    <tr>
                        <td><%= lista[i].cliId %></td>
                        <td><%= lista[i].cliNome %></td>
                        <td><%= lista[i].cliCpf %></td>

                        <td>
                            <%= lista[i].cliNascimento ? new Date(lista[i].cliNascimento).toLocaleDateString("pt-BR") : "---" %>
                        </td>

                        <td><%= lista[i].cliGenero %></td>
                        <td><%= lista[i].cliTelefone %></td>
                        <td><%= lista[i].cliEmail %></td>

                        <td>
                            <% if(lista[i].cliAtivo == "s") { %>
                                <span class="badge bg-success">Sim</span>
                            <% } else { %>
                                <span class="badge bg-danger">Não</span>
                            <% } %>
                        </td>

                        <td>
                            <div class="acoes">
                                <a href="/cliente/alterar/<%= lista[i].cliId %>" class="btn btn-primary btn-sm">
                                    <i class="fas fa-pen"></i>
                                </a>

                                <button data-id="<%= lista[i].cliId %>" class="btn btn-danger btn-sm btnExcluir" type="button">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

</div>
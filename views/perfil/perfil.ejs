<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Renove | Meu Perfil</title>

    <link rel="icon" href="/img/logo.png">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <style>
        body {
            background: #f4f6fb;
        }

        .perfil-container {
            min-height: 100vh;
            padding: 50px 15px;
        }

        .perfil-card {
            max-width: 950px;
            margin: auto;
            border: none;
            border-radius: 25px;
            overflow: hidden;
            box-shadow: 0 18px 45px rgba(0, 0, 0, .08);
        }

        .perfil-header {
            background: linear-gradient(135deg, #4f7cff, #6d4dff);
            color: white;
            padding: 45px;
        }

        .perfil-avatar {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: white;
            color: #4f7cff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 50px;
            margin-bottom: 15px;
        }

        .readonly-field {
            background: #eef2f7 !important;
            cursor: not-allowed;
        }

        .form-control,
        .form-select {
            border-radius: 14px;
            height: 52px;
        }

        .btn {
            border-radius: 14px;
            padding: 12px 20px;
            font-weight: 700;
        }

        .lock-text {
            font-size: 13px;
            color: #888;
            margin-top: 6px;
        }

        @media (max-width: 768px) {
            .perfil-container {
                padding: 20px 14px;
            }

            .perfil-card {
                border-radius: 18px;
            }

            .perfil-header {
                padding: 30px 24px;
                text-align: center;
            }

            .perfil-avatar {
                margin: 0 auto 15px;
                width: 85px;
                height: 85px;
                font-size: 42px;
            }

            .card-body {
                padding: 24px !important;
            }

            .form-control,
            .form-select {
                height: 54px;
                font-size: 16px;
            }

            .d-flex.flex-wrap {
                flex-direction: column;
            }

            .btn {
                width: 100%;
            }
        }
    </style>

</head>

<body>

    <div class="perfil-container">

        <div class="card perfil-card">

            <div class="perfil-header">

                <div class="perfil-avatar">
                    <i class="bi bi-person"></i>
                </div>

                <h2 class="mb-1">
                    Meu Perfil
                </h2>

                <% if(tipo=="usuario" ){ %>

                    <p class="mb-0">
                        Perfil administrativo do sistema
                    </p>

                    <% } else { %>

                        <p class="mb-0">
                            Gerencie suas informações pessoais
                        </p>

                        <% } %>

            </div>

            <div class="card-body p-5">

                <% if(tipo=="usuario" ){ %>

                    <div class="row">

                        <div class="col-md-4 mb-4">

                            <label>ID</label>

                            <input class="form-control readonly-field" readonly value="<%= dados.usuId %>">

                        </div>

                        <div class="col-md-8 mb-4">

                            <label>Nome</label>

                            <input class="form-control readonly-field" readonly value="<%= dados.usuNome %>">

                        </div>

                        <div class="col-md-12 mb-4">

                            <label>Email</label>

                            <input class="form-control readonly-field" readonly value="<%= dados.usuEmail %>">

                        </div>

                    </div>

                    <div class="alert alert-info">

                        Usuários administrativos não alteram dados por esta tela.

                    </div>

                    <% } else { %>

                        <form id="formPerfilCliente">

                            <div class="row">

                                <div class="col-md-3 mb-4">

                                    <label>ID</label>

                                    <input class="form-control readonly-field" readonly value="<%= dados.cliId %>">

                                </div>

                                <div class="col-md-9 mb-4">

                                    <label>Nome *</label>

                                    <input type="text" id="nome" class="form-control" value="<%= dados.cliNome %>">

                                </div>

                                <div class="col-md-6 mb-4">

                                    <label>CPF</label>

                                    <input class="form-control readonly-field" readonly value="<%= dados.cliCpf %>">

                                    <div class="lock-text">

                                        <i class="bi bi-lock"></i>

                                        CPF não pode ser alterado.

                                    </div>

                                </div>

                                <div class="col-md-6 mb-4">

                                    <label>Email</label>

                                    <input class="form-control readonly-field" readonly value="<%= dados.cliEmail %>">

                                    <div class="lock-text">

                                        <i class="bi bi-lock"></i>

                                        Email não pode ser alterado.

                                    </div>

                                </div>

                                <div class="col-md-6 mb-4">

                                    <label>Data nascimento *</label>

                                    <input type="date" id="nascimento" class="form-control"
                                        value="<%= dados.cliNascimento ? new Date(dados.cliNascimento).toISOString().split('T')[0] : '' %>">

                                </div>

                                <div class="col-md-6 mb-4">

                                    <label>Gênero *</label>

                                    <select id="genero" class="form-select">

                                        <option value="">

                                            Selecione

                                        </option>

                                        <option value="Masculino" <%=dados.cliGenero=="Masculino" ? "selected" : "" %>
                                            >

                                            Masculino

                                        </option>

                                        <option value="Feminino" <%=dados.cliGenero=="Feminino" ? "selected" : "" %>
                                            >

                                            Feminino

                                        </option>

                                        <option value="Outro" <%=dados.cliGenero=="Outro" ? "selected" : "" %>
                                            >

                                            Outro

                                        </option>

                                    </select>

                                </div>

                                <div class="col-md-6 mb-4">

                                    <label>Telefone *</label>

                                    <input type="text" id="telefone" class="form-control"
                                        value="<%= dados.cliTelefone %>">

                                </div>

                                <div class="col-md-6 mb-4">

                                    <label>Senha</label>

                                    <input class="form-control readonly-field" readonly value="********">

                                    <div class="lock-text">

                                        <i class="bi bi-lock"></i>

                                        Senha não pode ser alterada nesta área.

                                    </div>

                                </div>

                            </div>

                            <div class="d-flex flex-wrap gap-3 mt-3">

                                <button type="button" id="btnSalvarPerfil" class="btn btn-primary">

                                    <i class="bi bi-check-circle"></i>

                                    Salvar Alterações

                                </button>

                                <a href="/" class="btn btn-secondary">

                                    <i class="bi bi-house"></i>

                                    Home

                                </a>

                                <a href="/login/logout" class="btn btn-danger">

                                    <i class="bi bi-box-arrow-right"></i>

                                    Sair

                                </a>

                            </div>

                        </form>

                        <% } %>

            </div>

        </div>

    </div>

    <script src="/js/perfil/alterar.js"></script>

</body>

</html>
<script src="/js/categoria/alterar.js"></script>

<div>
    <h1>Alterar Categoria</h1>

    <input type="hidden" id="id" value="<%= categoria.catId %>">

    <div class="form-group">
        <label>Descrição</label>
        <input id="descricao" class="form-control" value="<%= categoria.catDescricao %>">
    </div>

    <div class="form-check">
        <input id="ativo" type="checkbox" <%= categoria.catAtivo == "s" ? "checked" : "" %>>
        <label>Ativo</label>
    </div>

    <br>

    <button id="btnAlterar" class="btn btn-primary">Salvar</button>
    <a href="/categoria" class="btn btn-secondary">Voltar</a>
</div>
<script src="/js/recebimento/cadastrar.js"></script>

<div>
    <h1>Novo Recebimento</h1>

    <div class="card">
        <div class="card-body">

            <div class="form-group">
                <label>Produto</label>
                <select id="produto" class="form-control">
                    <option value="">Selecione</option>

                    <% for(let i = 0; i < produtos.length; i++) { %>
                        <option value="<%= produtos[i].proCodigo %>">
                            <%= produtos[i].proNome %>
                        </option>
                    <% } %>
                </select>
            </div>

            <div class="form-group">
                <label>Quantidade</label>
                <input id="quantidade" type="number" class="form-control">
            </div>

            <div class="form-group">
                <label>Data</label>
                <input id="data" type="date" class="form-control">
            </div>

            <div class="form-group">
                <label>Lote</label>
                <input id="lote" class="form-control">
            </div>

            <div class="form-group">
                <label>Validade</label>
                <input id="validade" type="date" class="form-control">
            </div>

            <div class="form-group">
                <label>Observação</label>
                <textarea id="observacao" class="form-control"></textarea>
            </div>

            <button id="btnGravar" class="btn btn-primary">Gravar</button>
            <a href="/recebimento" class="btn btn-secondary">Voltar</a>

        </div>
    </div>
</div>
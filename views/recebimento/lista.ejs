<script src="/js/recebimento/lista.js"></script>

<div class="page-card">

    <div class="page-header">
        <h1>Recebimentos</h1>

        <a href="/recebimento/cadastrar" class="btn btn-primary">
            <i class="fas fa-plus"></i> Novo Recebimento
        </a>
    </div>

    <div class="table-responsive tabela-scroll">
        <table class="table table-striped table-hover align-middle tabela-sistema">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Produto</th>
                    <th>Quantidade</th>
                    <th>Data</th>
                    <th>Lote</th>
                    <th>Validade</th>
                    <th>Observação</th>
                    <th>Ações</th>
                </tr>
            </thead>

            <tbody>
                <% for(let i = 0; i < lista.length; i++) { %>
                    <tr>
                        <td><%= lista[i].rec_id %></td>
                        <td><%= lista[i].pro_nome %></td>
                        <td><%= lista[i].rec_quantidade %></td>

                        <td>
                            <%= lista[i].rec_data ? new Date(lista[i].rec_data).toLocaleDateString("pt-BR") : "---" %>
                        </td>

                        <td><%= lista[i].rec_lote || "---" %></td>

                        <td>
                            <%= lista[i].rec_validade ? new Date(lista[i].rec_validade).toLocaleDateString("pt-BR") : "---" %>
                        </td>

                        <td><%= lista[i].rec_observacao || "---" %></td>

                        <td>
                            <div class="acoes">
                                <a href="/recebimento/alterar/<%= lista[i].rec_id %>" class="btn btn-primary btn-sm">
                                    <i class="fas fa-pen"></i>
                                </a>

                                <button
                                    data-id="<%= lista[i].rec_id %>"
                                    class="btn btn-danger btn-sm btnExcluir"
                                    type="button">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

</div>
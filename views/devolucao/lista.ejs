<script src="/js/devolucao/lista.js"></script>

<div>

    <h1>Devoluções</h1>

    <a
        href="/devolucao/cadastrar"
        class="btn btn-primary mb-3">

        <i class="fas fa-plus"></i>
        Nova Devolução

    </a>

    <div class="card">

        <div class="card-body">

            <table class="table table-striped">

                <thead>

                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Produto</th>
                        <th>Quantidade</th>
                        <th>Motivo</th>
                        <th>Data</th>
                        <th>Observação</th>
                    </tr>

                </thead>

                <tbody>

                    <% for(let i = 0; i < lista.length; i++) { %>

                        <tr>

                            <td>
                                <%= lista[i].dev_id %>
                            </td>

                            <td>
                                <%= lista[i].cli_nome %>
                            </td>

                            <td>
                                <%= lista[i].pro_nome %>
                            </td>

                            <td>
                                <%= lista[i].dev_quantidade %>
                            </td>

                            <td>
                                <%= lista[i].dev_motivo %>
                            </td>

                            <td>
                                <%= new Date(lista[i].dev_data).toLocaleString("pt-BR") %>
                            </td>

                            <td>
                                <%= lista[i].dev_observacao || "---" %>
                            </td>

                        </tr>

                    <% } %>

                </tbody>

            </table>

        </div>

    </div>

</div>
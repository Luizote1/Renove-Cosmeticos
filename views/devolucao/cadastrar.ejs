<script src="/js/devolucao/cadastrar.js"></script>

<div>
    <h1>Nova Devolução</h1>

    <div class="card">
        <div class="card-body">

            <form method="GET" action="/devolucao/cadastrar" class="mb-4">
                <label>Buscar Pedido</label>

                <div style="display:flex; gap:10px; align-items:center;">
                    <input
                        type="text"
                        name="busca"
                        class="form-control"
                        placeholder="Digite ID do pedido, nome ou CPF"
                        value="<%= busca || '' %>">

                    <button type="submit" class="btn btn-primary" style="width:140px;">
                        <i class="fas fa-search"></i>
                        Buscar
                    </button>

                    <a href="/devolucao/cadastrar" class="btn btn-secondary" style="width:110px;">
                        Limpar
                    </a>
                </div>
            </form>

            <div class="form-group mb-3">
                <label>Pedido</label>

                <select id="pedido" class="form-control">
                    <option value="">Selecione</option>

                    <% for(let i = 0; i < pedidos.length; i++) { %>
                        <option value="<%= pedidos[i].ped_id %>">
                            Pedido #<%= pedidos[i].ped_id %> -
                            <%= pedidos[i].cli_nome %> -
                            R$ <%= Number(pedidos[i].ped_valortotal || 0).toFixed(2).replace(".", ",") %>
                        </option>
                    <% } %>
                </select>

                <% if(pedidos.length == 0) { %>
                    <small class="text-danger">
                        Nenhum pedido encontrado.
                    </small>
                <% } %>
            </div>

            <div class="form-group mb-3">
                <label>Motivo</label>

                <select id="motivo" class="form-control">
                    <option value="">Selecione</option>
                    <option value="Produto com defeito">Produto com defeito</option>
                    <option value="Produto danificado">Produto danificado</option>
                    <option value="Produto errado">Produto errado</option>
                    <option value="Arrependimento">Arrependimento</option>
                    <option value="Outro">Outro</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label>Observação</label>
                <textarea id="observacao" class="form-control" rows="4"></textarea>
            </div>

            <div class="form-group mb-4">
                <label>Data da Devolução</label>

                <input
                    type="text"
                    class="form-control"
                    value="<%= new Date().toLocaleString('pt-BR') %>"
                    readonly>
            </div>

            <button id="btnGravar" type="button" class="btn btn-primary">
                Gravar
            </button>

            <a href="/devolucao" class="btn btn-secondary">
                Voltar
            </a>

        </div>
    </div>
</div>
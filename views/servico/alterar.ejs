<script src="/js/servico/alterar.js"></script>

<div>
    <h1>Alterar Serviço</h1>

    <input type="hidden" id="id" value="<%= servico.serId %>">

    <div class="card">
        <div class="card-body">

            <div class="form-group">
                <label>Descrição</label>
                <input id="descricao" class="form-control" value="<%= servico.serDescricao %>">
            </div>

            <div class="form-group">
                <label>Detalhes</label>
                <textarea id="detalhes" class="form-control"><%= servico.serDetalhes || "" %></textarea>
            </div>

            <div class="form-group">
                <label>Valor</label>
                <input id="valor" type="number" step="0.01" class="form-control" value="<%= servico.serValor %>">
            </div>

            <div class="form-group">
                <label>Duração em minutos</label>
                <input id="duracao" type="number" class="form-control" value="<%= servico.serDuracaoMinutos %>">
            </div>

            <div class="form-group">
                <label>Cor no calendário</label>
                <input id="cor" type="color" class="form-control" value="<%= servico.serCor || '#ff5a00' %>">
            </div>

            <div class="form-check">
                <input id="ativo" type="checkbox" <%= servico.serAtivo == "s" ? "checked" : "" %>>
                <label for="ativo">Ativo</label>
            </div>

            <br>

            <button id="btnAlterar" class="btn btn-primary">Salvar</button>
            <a href="/servico" class="btn btn-secondary">Voltar</a>

        </div>
    </div>
</div>
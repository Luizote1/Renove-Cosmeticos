<div class="container-fluid">

    <h1>Serviços e Agenda</h1>

    <div class="row mb-4">

        <div class="col-md-4">

            <div class="card bg-primary text-white">

                <div class="card-body">

                    <h5>Serviços</h5>

                    <h2><%= lista.length %></h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card bg-success text-white">

                <div class="card-body">

                    <h5>Funcionários</h5>

                    <h2><%= profissionais.length %></h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card bg-warning text-dark">

                <div class="card-body">

                    <h5>Agenda</h5>

                    <h2>Online</h2>

                </div>

            </div>

        </div>

    </div>


    <div class="mb-3">

        <a
            href="/servico/cadastrar"
            class="btn btn-primary">

            <i class="fas fa-plus"></i>
            Novo Serviço

        </a>

        <button
            id="btnAbrirAgendamento"
            class="btn btn-success"
            type="button">

            <i class="fas fa-calendar-plus"></i>
            Novo Agendamento

        </button>

    </div>


    <div class="card mb-4">

        <div class="card-header">

            <strong>
                Calendário de Agendamentos
            </strong>

        </div>

        <div class="card-body">

            <div id="calendario"></div>

        </div>

    </div>


    <div class="card">

        <div class="card-header">

            <strong>
                Serviços cadastrados
            </strong>

        </div>

        <div class="card-body">

            <table class="table table-striped table-hover">

                <thead>

                    <tr>

                        <th>ID</th>
                        <th>Descrição</th>
                        <th>Valor</th>
                        <th>Duração</th>
                        <th>Status</th>
                        <th>Ações</th>

                    </tr>

                </thead>

                <tbody>

                    <% for(let i = 0; i < lista.length; i++) { %>

                        <tr>

                            <td>
                                <%= lista[i].serId %>
                            </td>

                            <td>

                                <strong>
                                    <%= lista[i].serDescricao %>
                                </strong>

                                <br>

                                <small>
                                    <%= lista[i].serDetalhes || "" %>
                                </small>

                            </td>

                            <td>

                                R$
                                <%= Number(lista[i].serValor)
                                .toFixed(2)
                                .replace(".", ",") %>

                            </td>

                            <td>

                                <%= lista[i].serDuracaoMinutos %> min

                            </td>

                            <td>

                                <% if(lista[i].serAtivo == "s") { %>

                                    <span class="badge bg-success">
                                        Ativo
                                    </span>

                                <% } else { %>

                                    <span class="badge bg-secondary">
                                        Inativo
                                    </span>

                                <% } %>

                            </td>

                            <td>

                                <a
                                    href="/servico/alterar/<%= lista[i].serId %>"
                                    class="btn btn-primary btn-sm">

                                    <i class="fas fa-pen"></i>

                                </a>

                                <button
                                    data-id="<%= lista[i].serId %>"
                                    class="btn btn-danger btn-sm btnExcluir">

                                    <i class="fas fa-trash"></i>

                                </button>

                            </td>

                        </tr>

                    <% } %>

                </tbody>

            </table>

        </div>

    </div>

</div>


<!-- MODAL AGENDAMENTO -->

<div
    class="modal fade"
    id="modalAgendamento"
    tabindex="-1"
    aria-hidden="true">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Novo Agendamento
                </h5>

            </div>

            <div class="modal-body">

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label>Cliente</label>

                        <input
                            id="cliente"
                            class="form-control">

                    </div>


                    <div class="col-md-6 mb-3">

                        <label>Telefone</label>

                        <input
                            id="telefone"
                            class="form-control">

                    </div>


                    <div class="col-md-6 mb-3">

                        <label>Serviço</label>

                        <select
                            id="servico"
                            class="form-control">

                            <option value="">
                                Selecione
                            </option>

                            <% for(let i=0; i < servicosAtivos.length; i++) { %>

                                <option value="<%= servicosAtivos[i].serId %>">

                                    <%= servicosAtivos[i].serDescricao %>

                                </option>

                            <% } %>

                        </select>

                    </div>


                    <div class="col-md-6 mb-3">

                        <label>Funcionário</label>

                        <select
                            id="profissional"
                            class="form-control">

                            <option value="">
                                Selecione
                            </option>

                            <% for(let i=0; i < profissionais.length; i++) { %>

                                <option value="<%= profissionais[i].usuId %>">

                                    <%= profissionais[i].usuNome %>

                                </option>

                            <% } %>

                        </select>

                    </div>


                    <div class="col-md-6 mb-3">

                        <label>Data</label>

                        <input
                            id="data"
                            type="date"
                            class="form-control">

                    </div>


                    <div class="col-md-6 mb-3">

                        <label>Hora</label>

                        <input
                            id="hora"
                            type="time"
                            class="form-control">

                    </div>


                    <div class="col-md-12 mb-3">

                        <label>Observação</label>

                        <textarea
                            id="observacao"
                            class="form-control"></textarea>

                    </div>

                </div>

            </div>


            <div class="modal-footer">

                <button
                    type="button"
                    class="btn btn-secondary"
                    data-bs-dismiss="modal">

                    Fechar

                </button>

                <button
                    id="btnAgendar"
                    class="btn btn-success">

                    Agendar

                </button>

            </div>

        </div>

    </div>

</div>


<input
    type="hidden"
    id="eventosJson"
    value='<%- eventosJson %>'>


<link
rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css">


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>

<script src="/js/servico/lista.js"></script>
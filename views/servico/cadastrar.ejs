<script src="/js/servico/cadastrar.js"></script>

<div>
    <h1>Cadastrar Serviço</h1>

    <div class="card">
        <div class="card-body">

            <div class="form-group">
                <label>Descrição</label>
                <input id="descricao" class="form-control">
            </div>

            <div class="form-group">
                <label>Detalhes</label>
                <textarea id="detalhes" class="form-control"></textarea>
            </div>

            <div class="form-group">
                <label>Valor</label>
                <input id="valor" type="number" step="0.01" class="form-control">
            </div>

            <div class="form-group">
                <label>Duração em minutos</label>
                <input id="duracao" type="number" class="form-control">
            </div>

            <div class="form-group">
                <label>Cor no calendário</label>
                <input id="cor" type="color" class="form-control" value="#ff5a00">
            </div>

            <div class="form-check">
                <input id="ativo" type="checkbox" checked>
                <label for="ativo">Ativo</label>
            </div>

            <br>

            <button id="btnGravar" class="btn btn-primary">Gravar</button>
            <a href="/servico" class="btn btn-secondary">Voltar</a>

        </div>
    </div>
</div>
<!DOCTYPE html>
<html lang="pt-br">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Renove | Login</title>

    <link rel="icon" href="/img/logo.png">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/bootstrap.css">

    <link rel="stylesheet" href="/css/login.css?v=50">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

</head>

<body class="theme-light">

    <!-- LOADING -->

    <div id="loadingOverlay" class="loading-overlay">

        <svg class="pill-loader-svg" viewBox="0 0 100 30">

            <path
                class="pill-half-filled"
                d="M50 0 L15 0 A15 15 0 0 0 15 30 L50 30 Z" />

            <path
                class="pill-half-outline"
                d="M50 0 L85 0 A15 15 0 0 1 85 30 L50 30 Z" />

        </svg>

    </div>

    <!-- NAVBAR -->

    <nav class="navbar navbar-expand-lg">

        <div class="container-fluid">

            <a class="navbar-brand" href="/">

                <img class="images" src="/img/logotipo.png">

            </a>

            <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarTogglerDemo02">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse" id="navbarTogglerDemo02">

                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    <li class="nav-item">
                        <a class="nav-link" href="/">
                            Início
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/produtos">
                            Produtos
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/cadastro">
                            Registrar
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link active" href="/login">
                            Login
                        </a>
                    </li>

                </ul>

            </div>

        </div>

    </nav>

    <!-- LOGIN -->

    <main class="page">

        <section class="login-box">

            <% if (msg && msg !== "") { %>

                <div class="alert alert-danger text-center" style="margin-bottom: 15px;">

                    <%= msg %>

                </div>

            <% } %>

            <form action="/login" method="POST" id="formLogin">

                <div class="form-group">

                    <label for="emailCpf">
                        E-mail ou CPF
                    </label>

                    <input
                        type="text"
                        id="emailCpf"
                        name="emailCpf"
                        class="input"
                        placeholder="Digite seu e-mail ou CPF">

                    <div class="helper-error" id="emailCpfError">
                        Informe um e-mail ou CPF válido.
                    </div>

                </div>

                <div class="form-group">

                    <label for="senha">
                        Senha
                    </label>

                    <div class="password-wrapper">

                        <input
                            type="password"
                            id="senha"
                            name="senha"
                            class="input"
                            placeholder="Digite sua senha">

                        <button
                            type="button"
                            class="toggle-pass"
                            id="toggleSenha">

                            👁

                        </button>

                    </div>

                    <div class="helper-error" id="senhaError">
                        Digite sua senha.
                    </div>

                </div>

                <button
                    type="submit"
                    class="btn btn-primary">

                    Entrar

                </button>

                <div class="forgot-password">

                    <a href="#">
                        Esqueci a senha
                    </a>

                </div>

                <div class="bottom-link">

                    Não tem conta?

                    <a href="/cadastro">
                        Cadastre-se
                    </a>

                </div>

            </form>

        </section>

    </main>

    <!-- VLIBRAS -->

    <div vw class="enabled">

        <div vw-access-button class="active"></div>

        <div vw-plugin-wrapper>
            <div class="vw-plugin-top-wrapper"></div>
        </div>

    </div>

    <script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>

    <script>
        new window.VLibras.Widget(
            'https://vlibras.gov.br/app'
        );
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

    <script src="/js/login.js"></script>

    <script src="/js/site.js"></script>

</body>

</html>
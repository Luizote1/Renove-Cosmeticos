<!DOCTYPE html>
<html lang="pt-br">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Renove | Cadastro</title>

    <link rel="icon" href="/img/logo.png">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/bootstrap.css">

    <link rel="stylesheet" href="/css/cadastro.css?v=50">

    <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

</head>

<body class="theme-light">

    <!-- LOADING -->

    <div id="loadingOverlay" class="loading-overlay">

        <svg class="pill-loader-svg" viewBox="0 0 100 30">

            <path class="pill-half-filled"
                d="M50 0 L15 0 A15 15 0 0 0 15 30 L50 30 Z" />

            <path class="pill-half-outline"
                d="M50 0 L85 0 A15 15 0 0 1 85 30 L50 30 Z" />

        </svg>

    </div>

    <!-- NAVBAR -->

    <nav class="navbar navbar-expand-lg">

        <div class="container-fluid">

            <a class="navbar-brand" href="/">
                <img class="images" src="/img/logotipo.png">
            </a>

            <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarTogglerDemo02">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse" id="navbarTogglerDemo02">

                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    <li class="nav-item">
                        <a class="nav-link" href="/">
                            Início
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/produtos">
                            Produtos
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link active" href="/cadastro">
                            Registrar
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/login">
                            Login
                        </a>
                    </li>

                </ul>

            </div>

        </div>

    </nav>

    <!-- FORM -->

    <main class="page">

        <section class="wizard">

            <div class="step-header">

                <div class="step-text" id="stepLabel">
                    Passo 1 de 2
                </div>

                <div class="progress" id="progressBar">
                    <span class="active"></span>
                    <span></span>
                </div>

            </div>

            <div class="panel">

                <form id="cadastroForm">

                    <div class="step active" data-step="1">

                        <h1>Vamos começar?</h1>

                        <p class="subtitle">
                            Complete os dados e crie seu cadastro.
                        </p>

                        <div class="form-group">

                            <label for="cpf">CPF</label>

                            <input
                                class="input"
                                id="cpf"
                                type="text"
                                maxlength="14"
                                placeholder="000.000.000-00">

                            <div class="helper-error" id="cpfError">
                                Digite um CPF válido.
                            </div>

                        </div>

                        <div class="form-group">

                            <label for="nome">
                                Nome completo
                            </label>

                            <input
                                class="input"
                                id="nome"
                                type="text"
                                placeholder="Seu nome completo">

                        </div>

                        <div class="form-row">

                            <div class="form-group">

                                <label for="nascimento">
                                    Data de nascimento
                                </label>

                                <input
                                    class="input"
                                    id="nascimento"
                                    type="date">

                            </div>

                            <div class="form-group">

                                <label for="genero">
                                    Gênero
                                </label>

                                <select class="select" id="genero">

                                    <option value="">
                                        Selecione
                                    </option>

                                    <option>
                                        Masculino
                                    </option>

                                    <option>
                                        Feminino
                                    </option>

                                    <option>
                                        Não informar
                                    </option>

                                    <option>
                                        Outro
                                    </option>

                                </select>

                            </div>

                        </div>

                        <div class="form-group">

                            <label for="telefone">
                                Telefone celular
                            </label>

                            <input
                                class="input"
                                id="telefone"
                                type="text"
                                maxlength="15"
                                placeholder="(00) 00000-0000">

                        </div>

                        <div class="form-group">

                            <label for="email">
                                Seu e-mail
                            </label>

                            <input
                                class="input"
                                id="email"
                                type="email"
                                placeholder="seuemail@exemplo.com">

                        </div>

                        <label class="checkbox-group">

                            <input type="checkbox" id="termos">

                            <span>

                                Li e aceito os

                                <a href="#">
                                    Termos de uso
                                </a>

                                e

                                <a href="#">
                                    Políticas de privacidade
                                </a>

                            </span>

                        </label>

                        <button
                            class="btn btn-primary"
                            type="button"
                            onclick="nextStep(1)">

                            Continuar

                        </button>

                        <div class="bottom-link">

                            Já tem conta?

                            <a href="/login">
                                Entrar
                            </a>

                        </div>

                    </div>

                </form>

            </div>

        </section>

    </main>

    <!-- VLIBRAS -->

    <div vw class="enabled">
        <div vw-access-button class="active"></div>

        <div vw-plugin-wrapper>
            <div class="vw-plugin-top-wrapper"></div>
        </div>
    </div>

    <script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>

    <script>
        new window.VLibras.Widget(
            'https://vlibras.gov.br/app'
        );
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

    <script src="/js/registrar.js"></script>

    <script src="/js/site.js"></script>

</body>

</html>
<script src="/js/produto/cadastrar.js"></script>

<div>
    <h1>Cadastrar Produto</h1>

    <div class="card">
        <div class="card-body">

            <div class="form-group">
                <label for="codigo">Código</label>
                <input 
                    id="codigo" 
                    type="text" 
                    class="form-control" 
                    placeholder="Ex: REN-006"
                >
            </div>

            <div class="form-group">
                <label for="nome">Nome</label>
                <input id="nome" type="text" class="form-control">
            </div>

            <div class="form-group">
                <label for="descricao">Descrição</label>
                <textarea id="descricao" class="form-control"></textarea>
            </div>

            <div class="form-group">
                <label for="preco">Preço</label>
                <input id="preco" type="number" step="0.01" class="form-control">
            </div>

            <div class="form-group">
                <label for="estoque">Estoque</label>
                <input id="estoque" type="number" class="form-control">
            </div>

            <div class="form-group">
                <label for="validade">Data de Validade</label>
                <input id="validade" type="date" class="form-control">
            </div>

            <div class="form-group">
                <label for="categoria">Categoria</label>

                <select id="categoria" class="form-control">
                    <option value="">Selecione</option>

                    <% for(let i = 0; i < listaCategorias.length; i++) { %>
                        <option value="<%= listaCategorias[i].catId %>">
                            <%= listaCategorias[i].catDescricao %>
                        </option>
                    <% } %>

                </select>
            </div>

            <div class="form-group">
                <label for="tipo">Tipo de Produto</label>

                <select id="tipo" class="form-control">
                    <option value="">Selecione</option>

                    <% for(let i = 0; i < listaTipos.length; i++) { %>
                        <option value="<%= listaTipos[i].tipId %>">
                            <%= listaTipos[i].tipDescricao %>
                        </option>
                    <% } %>

                </select>
            </div>

            <div class="form-group">
                <label for="laboratorio">Laboratório</label>

                <select id="laboratorio" class="form-control">
                    <option value="">Selecione</option>

                    <% for(let i = 0; i < listaLaboratorios.length; i++) { %>
                        <option value="<%= listaLaboratorios[i].labId %>">
                            <%= listaLaboratorios[i].labNome %>
                        </option>
                    <% } %>

                </select>
            </div>

            <div class="form-group">
                <label for="imagem">Foto do Produto</label>

                <input
                    id="imagem"
                    type="file"
                    class="form-control"
                    accept="image/*"
                >
            </div>

            <div class="form-group form-check">

                <input
                    id="ativo"
                    type="checkbox"
                    class="form-check-input"
                    checked
                >

                <label class="form-check-label" for="ativo">
                    Ativo
                </label>

            </div>

            <div class="mt-3">

                <button id="btnGravar" class="btn btn-primary">
                    Gravar
                </button>

                <a href="/produtos/listar" class="btn btn-secondary">
                    Voltar
                </a>

            </div>

        </div>
    </div>
</div>
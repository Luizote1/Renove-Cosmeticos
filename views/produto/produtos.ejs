<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Renove | Produtos</title>

  <link rel="icon" href="/img/logo.png">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/bootstrap.css">
  <link rel="stylesheet" href="/css/themes.css?v=90">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<body class="theme-light">

  <!-- LOADING -->
  <div id="loadingOverlay" class="loading-overlay">
    <svg class="pill-loader-svg" viewBox="0 0 100 30">
      <path class="pill-half-filled" d="M50 0 L15 0 A15 15 0 0 0 15 30 L50 30 Z" />
      <path class="pill-half-outline" d="M50 0 L85 0 A15 15 0 0 1 85 30 L50 30 Z" />
    </svg>
  </div>

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid navbar-mobile-fix">

      <!-- LOGO -->
      <a class="navbar-brand navbar-logo-fix" href="/">
        <img class="images" src="/img/logotipo.png" alt="Renove">
      </a>

      <!-- AÇÕES MOBILE -->
      <div class="navbar-actions-fix d-lg-none">

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarTogglerDemo02"
          aria-controls="navbarTogglerDemo02" aria-expanded="false" aria-label="Abrir menu">

          <span class="navbar-toggler-icon"></span>

        </button>

        <button class="btn cart-navbar-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#cartOffcanvas"
          aria-label="Abrir carrinho">

          <i class="bi bi-cart3"></i>

          <span class="cart-navbar-count" id="cartCountMobile">
            0
          </span>

        </button>

      </div>

      <!-- MENU -->
      <div class="collapse navbar-collapse" id="navbarTogglerDemo02">

        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">

          <li class="nav-item">
            <a class="nav-link" href="/">
              Início
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link active" href="/produtos">
              Produtos
            </a>
          </li>

          <% if(!usuarioLogado){ %>

            <li class="nav-item">
              <a class="nav-link" href="/cadastro">
                Registrar
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/login">
                Login
              </a>
            </li>

            <% } else { %>

              <li class="nav-item dropdown">

                <a class="nav-link dropdown-toggle" href="#" id="menuConta" role="button" data-bs-toggle="dropdown"
                  aria-expanded="false">
                  <i class="bi bi-person-circle"></i>
                  Minha Conta
                </a>

                <ul class="dropdown-menu dropdown-menu-end">

                  <li>
                    <a class="dropdown-item" href="/perfil">
                      <i class="bi bi-person"></i>
                      Meu Perfil
                    </a>
                  </li>

                  <li>
                    <a class="dropdown-item" href="/pedido/meus-pedidos">
                      <i class="bi bi-bag-check"></i>
                      Meus Pedidos
                    </a>
                  </li>

                  <% if(tipoLogado=="usuario" ){ %>

                    <li>
                      <a class="dropdown-item" href="/usuario">
                        <i class="bi bi-gear"></i>
                        Sistema
                      </a>
                    </li>

                    <% } %>

                      <li>
                        <hr class="dropdown-divider">
                      </li>

                      <li>
                        <button class="dropdown-item text-danger" type="button"
                          onclick="window.location='/login/logout'">

                          <i class="bi bi-box-arrow-right"></i>
                          Sair

                        </button>
                      </li>

                </ul>

              </li>

              <% } %>

        </ul>

        <!-- CARRINHO DESKTOP -->
        <div class="d-none d-lg-flex ms-3">

          <button class="btn cart-navbar-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#cartOffcanvas"
            aria-label="Abrir carrinho">

            <i class="bi bi-cart3"></i>

            <span class="cart-navbar-count" id="cartCount">
              0
            </span>

          </button>

        </div>

      </div>

    </div>
  </nav>

  <!-- CONTEÚDO -->
  <div class="container mt-4">

    <div class="row mb-5">
      <div class="col-12 text-center">

        <h1 class="display-3 fw-bold mb-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
          background-clip: text;">
          Nossos Produtos
        </h1>

        <p class="lead fs-4 text-muted">
          Descubra nossa seleção premium de cosméticos e produtos de beleza
        </p>

        <div class="mt-4">
          <div class="d-flex justify-content-center align-items-center gap-3 flex-wrap">

            <div class="d-flex align-items-center">
              <i class="bi bi-shield-check text-success me-2"></i>
              <span class="text-muted">Produtos Testados</span>
            </div>

            <div class="d-flex align-items-center">
              <i class="bi bi-truck text-primary me-2"></i>
              <span class="text-muted">Entrega Rápida</span>
            </div>

            <div class="d-flex align-items-center">
              <i class="bi bi-heart text-danger me-2"></i>
              <span class="text-muted">Qualidade Premium</span>
            </div>

          </div>
        </div>

      </div>
    </div>

    <!-- FILTROS -->
    <div class="filter-section">
      <div class="row g-3">

        <div class="col-md-4">
          <label for="searchInput" class="form-label">
            Buscar produtos
          </label>

          <input type="text" class="form-control" id="searchInput" placeholder="Digite o nome do produto...">
        </div>

        <div class="col-md-3">
          <label for="categoryFilter" class="form-label">
            Categoria
          </label>

          <select class="form-select" id="categoryFilter">
            <option value="">Todas as categorias</option>

            <% let categoriasUnicas=[]; %>

              <% for(let i=0; i < lista.length; i++) { %>

                <% if(!categoriasUnicas.includes(lista[i].catDescricao)) { %>

                  <% categoriasUnicas.push(lista[i].catDescricao); %>

                    <% } %>

                      <% } %>

                        <% for(let i=0; i < categoriasUnicas.length; i++) { %>

                          <option value="<%= categoriasUnicas[i] %>">
                            <%= categoriasUnicas[i] %>
                          </option>

                          <% } %>

          </select>
        </div>

        <div class="col-md-3">
          <label for="priceFilter" class="form-label">
            Faixa de preço
          </label>

          <select class="form-select" id="priceFilter">
            <option value="">Todos os preços</option>
            <option value="0-50">Até R$ 50</option>
            <option value="50-100">R$ 50 - R$ 100</option>
            <option value="100-200">R$ 100 - R$ 200</option>
            <option value="200+">Acima de R$ 200</option>
          </select>
        </div>

        <div class="col-md-2">
          <label class="form-label">&nbsp;</label>

          <button class="btn btn-primary w-100" id="btnFiltrar">
            <i class="bi bi-funnel"></i>
            Filtrar
          </button>
        </div>

      </div>
    </div>

    <!-- RESULTADOS -->
    <div class="row mb-3">
      <div class="col-12">

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">

          <p class="mb-0" id="resultsCount">
            Mostrando todos os produtos
          </p>

          <div class="d-flex align-items-center">
            <label class="form-label me-2 mb-0">
              Ordenar por:
            </label>

            <select class="form-select form-select-sm" style="width: auto;" id="sortSelect">
              <option value="name">Nome</option>
              <option value="price-low">Menor preço</option>
              <option value="price-high">Maior preço</option>
            </select>
          </div>

        </div>

      </div>
    </div>

    <div class="row g-4" id="productsGrid"></div>

  </div>

  <!-- MODAL PRODUTO -->
  <div class="modal fade product-modal" id="productModal" tabindex="-1" aria-labelledby="productModalLabel"
    aria-hidden="true">

    <div class="modal-dialog modal-lg">
      <div class="modal-content">

        <div class="modal-header">
          <h5 class="modal-title" id="productModalLabel">
            Detalhes do Produto
          </h5>

          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar">
          </button>
        </div>

        <div class="modal-body" id="productModalBody"></div>

      </div>
    </div>

  </div>

  <!-- CARRINHO -->
  <div class="offcanvas offcanvas-end cart-panel" tabindex="-1" id="cartOffcanvas" aria-labelledby="cartOffcanvasLabel">

    <div class="offcanvas-header border-bottom">

      <div class="d-flex align-items-center gap-2">
        <i class="bi bi-cart3 fs-4 text-primary"></i>

        <div>
          <h5 class="mb-0 fw-bold" id="cartOffcanvasLabel">
            Seu Carrinho
          </h5>

          <small class="text-muted">
            Seus produtos selecionados
          </small>
        </div>
      </div>

      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Fechar">
      </button>

    </div>

    <div class="offcanvas-body">

      <div id="cartItems"></div>

      <div class="cart-footer">

        <div class="d-flex justify-content-between mb-3">
          <span>Frete</span>

          <strong>
            Grátis
          </strong>
        </div>

        <hr>

        <div class="d-flex justify-content-between fs-5">
          <strong>Total</strong>

          <strong class="text-primary" id="cartTotal">
            R$ 0,00
          </strong>
        </div>

        <button class="btn btn-primary w-100 mt-4 py-3" onclick="checkout()">

          <i class="bi bi-credit-card me-2"></i>
          Finalizar Compra

        </button>

      </div>

    </div>

  </div>

  <!-- FOOTER -->
  <footer class="footer-techmode">

    <div class="footer-container">

      <div class="footer-coluna" id="footer-logo-col">
        <img src="/img/logo.png" alt="Logo Renove" class="footer-logo">

        <p class="footer-slogan">
          Inovação e tecnologia ao seu alcance.
        </p>
      </div>

      <div class="footer-coluna">
        <h4>Empresa</h4>

        <ul>
          <li><a href="#">Sobre Nós</a></li>
          <li><a href="#">Carreiras</a></li>
          <li><a href="#">Imprensa</a></li>
          <li><a href="#">Contato</a></li>
        </ul>
      </div>

      <div class="footer-coluna">
        <h4>Suporte</h4>

        <ul>
          <li><a href="#">FAQ</a></li>
          <li><a href="#">Central de Ajuda</a></li>
          <li><a href="#">Termos de Serviço</a></li>
          <li><a href="#">Política de Privacidade</a></li>
        </ul>
      </div>

      <div class="footer-coluna">
        <h4>Siga-nos</h4>

        <div class="footer-social-links">
          <a href="#" aria-label="Facebook" title="Facebook">
            <i class="bi bi-facebook"></i>
          </a>

          <a href="#" aria-label="Instagram" title="Instagram">
            <i class="bi bi-instagram"></i>
          </a>

          <a href="#" aria-label="Twitter" title="Twitter">
            <i class="bi bi-twitter-x"></i>
          </a>
        </div>
      </div>

    </div>

    <div class="footer-bottom-bar">
      <p>
        &copy; 2025 Tech Mode. Todos os direitos reservados.
        Desenvolvido por
        <a href="https://luizote1.github.io/tech-mode/" target="_blank" rel="noopener noreferrer">
          Tech Mode
        </a>.
      </p>
    </div>

  </footer>

  <!-- VLIBRAS -->
  <div vw class="enabled">
    <div vw-access-button class="active"></div>

    <div vw-plugin-wrapper>
      <div class="vw-plugin-top-wrapper"></div>
    </div>
  </div>

  <script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>

  <script>
    new window.VLibras.Widget(
      'https://vlibras.gov.br/app'
    );
  </script>

  <script id="produtos-json" type="application/json">
    <%- produtosJson %>
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/products.js"></script>
  <script src="/js/site.js"></script>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const cartCount = document.getElementById("cartCount");
      const cartCountMobile = document.getElementById("cartCountMobile");

      function sincronizarCarrinhoNavbar() {
        if (cartCount && cartCountMobile) {
          cartCountMobile.textContent = cartCount.textContent;
        }
      }

      sincronizarCarrinhoNavbar();
      setInterval(sincronizarCarrinhoNavbar, 300);
    });
  </script>

  <!-- BOTÃO WHATSAPP -->
  <a href="https://wa.me/5514999999999?text=Olá! Gostaria de agendar um serviço." class="whatsapp-float" target="_blank"
    title="Agendar Serviço">
    <i class="bi bi-whatsapp"></i>
  </a>

  <style>
    .whatsapp-float {
      position: fixed;
      bottom: 25px;
      right: 25px;
      width: 65px;
      height: 65px;
      background: #25D366;
      color: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 34px;
      text-decoration: none;
      box-shadow: 0 8px 25px rgba(37, 211, 102, .4);
      z-index: 100;
      /* menor que o carrinho */
      transition: all .3s ease;
    }

    .whatsapp-float:hover {
      transform: scale(1.1);
      color: #fff;
      text-decoration: none;
      box-shadow: 0 12px 35px rgba(37, 211, 102, .6);
    }

    .whatsapp-float::before {
      content: '';
      position: absolute;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      background: rgba(37, 211, 102, .4);
      animation: pulseWhats 2s infinite;
      z-index: -1;
    }

    .whatsapp-float i {
      line-height: 1;
    }

    @keyframes pulseWhats {
      0% {
        transform: scale(1);
        opacity: .8;
      }

      100% {
        transform: scale(1.8);
        opacity: 0;
      }
    }

    /* RESPONSIVO */
    @media (max-width: 768px) {
      .whatsapp-float {
        width: 58px;
        height: 58px;
        font-size: 30px;
        right: 15px;
        bottom: 15px;
      }
    }
  </style>

</body>

</html>
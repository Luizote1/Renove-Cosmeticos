<script src="/js/tipoProduto/lista.js"></script>

<div class="page-card">

    <div class="page-header">

        <h1>Tipos de Produtos</h1>

        <a href="/tipoproduto/cadastrar" class="btn btn-primary">
            <i class="fas fa-plus"></i>
            Novo Tipo
        </a>

    </div>

    <div class="table-responsive tabela-scroll">

        <table class="table table-striped table-hover align-middle tabela-sistema">

            <thead>
                <tr>
                    <th>ID</th>
                    <th>Descrição</th>
                    <th>Ativo</th>
                    <th>Ações</th>
                </tr>
            </thead>

            <tbody>

                <% for(let i = 0; i < lista.length; i++) { %>

                    <tr>

                        <td>
                            <%= lista[i].tipId %>
                        </td>

                        <td>
                            <%= lista[i].tipDescricao %>
                        </td>

                        <td>

                            <% if(lista[i].tipAtivo == 's') { %>

                                <span class="badge bg-success">
                                    Sim
                                </span>

                            <% } else { %>

                                <span class="badge bg-danger">
                                    Não
                                </span>

                            <% } %>

                        </td>

                        <td>

                            <div class="acoes">

                                <a
                                    href="/tipoproduto/alterar/<%= lista[i].tipId %>"
                                    class="btn btn-primary btn-sm"
                                >
                                    <i class="fas fa-pen"></i>
                                </a>

                                <button
                                    data-id="<%= lista[i].tipId %>"
                                    class="btn btn-danger btn-sm btnExcluir"
                                >
                                    <i class="fas fa-trash"></i>
                                </button>

                            </div>

                        </td>

                    </tr>

                <% } %>

            </tbody>

        </table>

    </div>

</div>
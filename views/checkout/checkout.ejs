<title>Renove | Finalizar Compra</title>
<link rel="icon" href="/img/logo.png">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/themes.css">

<style>
  .navbar {
    position: relative;
    z-index: 99999 !important;
  }

  .dropdown-menu {
    z-index: 100000 !important;
  }

  .sticky-top {
    z-index: 1 !important;
  }

  .card {
    position: relative;
    z-index: 1;
  }
</style>


<body>

  <!-- LOADING -->
  <div id="loadingOverlay" class="loading-overlay">
    <svg class="pill-loader-svg" viewBox="0 0 100 30" xmlns="http://www.w3.org/2000/svg">
      <path class="pill-half-filled" d="M50 0 L15 0 A15 15 0 0 0 15 30 L50 30 Z" />
      <path class="pill-half-outline" d="M50 0 L85 0 A15 15 0 0 1 85 30 L50 30 Z" />
    </svg>
  </div>
  <!-- LOADING -->

  <nav class="navbar navbar-expand-lg">

    <div class="container-fluid">

      <a class="navbar-brand" href="/">
        <img class="images" src="/img/logotipo.png">
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarTogglerDemo02">

        <span class="navbar-toggler-icon"></span>

      </button>

      <div class="collapse navbar-collapse" id="navbarTogglerDemo02">

        <ul class="navbar-nav me-auto mb-2 mb-lg-0">

          <li class="nav-item">
            <a class="nav-link" href="/">Início</a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/produtos">Produtos</a>
          </li>

          <% if(!usuarioLogado){ %>

            <li class="nav-item">
              <a class="nav-link" href="/cadastro">
                Registrar
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/login">
                Login
              </a>
            </li>

            <% } else { %>

              <li class="nav-item dropdown">

                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">

                  <i class="bi bi-person-circle"></i>
                  Minha Conta

                </a>

                <ul class="dropdown-menu dropdown-menu-end">

                  <li>
                    <a class="dropdown-item" href="/perfil">

                      <i class="bi bi-person"></i>
                      Meu Perfil

                    </a>
                  </li>

                  <li>
                    <a class="dropdown-item" href="/pedido/meus-pedidos">
                      <i class="bi bi-bag-check"></i>
                      Meus Pedidos
                    </a>
                  </li>

                  <% if(tipoLogado=="usuario" ){ %>

                    <li>
                      <a class="dropdown-item" href="/usuario">

                        <i class="bi bi-gear"></i>
                        Sistema

                      </a>
                    </li>

                    <% } %>

                      <li>
                        <hr class="dropdown-divider">
                      </li>

                      <li>

                        <button class="dropdown-item text-danger" type="button"
                          onclick="window.location='/login/logout'">

                          <i class="bi bi-box-arrow-right"></i>
                          Sair

                        </button>

                      </li>

                </ul>

              </li>

              <% } %>

        </ul>

        <div class="d-flex align-items-center">

          <button class="btn btn-outline-primary me-2" type="button" data-bs-toggle="offcanvas"
            data-bs-target="#cartOffcanvas">

            <i class="bi bi-cart3"></i>

            <span class="badge bg-danger ms-1" id="cartCount">0</span>

          </button>

        </div>

      </div>

    </div>

  </nav>

  <div class="container mt-4">
    <div class="row">
      <div class="col-lg-8">
        <!-- Formulário de Checkout -->
        <div class="card shadow-sm" style="border-radius: 20px; border: none;">
          <div class="card-header"
            style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-radius: 20px 20px 0 0; border: none;">
            <h4 class="mb-0"><i class="bi bi-credit-card me-2"></i>Informações de Pagamento</h4>
          </div>
          <div class="card-body">
            <form id="checkoutForm">
              <!-- Informações Pessoais -->


              <!-- Endereço de Entrega -->
              <div class="row mb-4">
                <div class="col-12">
                  <h5 class="border-bottom pb-2 mb-3">Endereço de Entrega</h5>
                </div>
                <div class="col-md-4 mb-3">
                  <label for="zipCode" class="form-label">CEP *</label>
                  <input type="text" class="form-control" maxlength="9" id="zipCode" required>
                </div>
                <div class="col-md-4 mb-3">
                  <label for="city" class="form-label">Cidade *</label>
                  <input type="text" class="form-control" id="cidade" required>
                </div>
                <div class="col-md-4 mb-3">
                  <label for="city" class="form-label">Estado *</label>
                  <input type="text" class="form-control" id="estado" required>
                </div>
                <div class="col-12 mb-3">
                  <label for="address" class="form-label">Rua *</label>
                  <input type="text" class="form-control" id="rua" required>
                </div>
                <div class="col-12 mb-3">
                  <label for="address" class="form-label">Bairro *</label>
                  <input type="text" class="form-control" id="bairro" required>
                </div>
                <div class="col-md-4 mb-3">
                  <label for="address" class="form-label">Número *</label>
                  <input type="number" class="form-control" id="numero" required>
                </div>
                <div class="col-8 mb-3">
                  <label for="address" class="form-label">Complemento (opicional)</label>
                  <input type="text" class="form-control" id="complemento">
                </div>


              </div>

              <!-- Método de Pagamento -->
              <div class="row mb-4">
                <div class="col-12">
                  <h5 class="border-bottom pb-2 mb-3">Método de Pagamento</h5>
                </div>
                <div class="col-12 mb-3">
                  <div class="form-check">
                    <input class="form-check-input" type="radio" name="paymentMethod" id="creditCard" value="credit"
                      checked>
                    <label class="form-check-label" for="creditCard">
                      <i class="bi bi-credit-card me-2"></i>Cartão de Crédito
                    </label>
                  </div>
                  <div class="form-check">
                    <input class="form-check-input" type="radio" name="paymentMethod" id="pix" value="pix">
                    <label class="form-check-label" for="pix">
                      <i class="bi bi-qr-code me-2"></i>PIX
                    </label>
                  </div>
                  <div class="form-check">
                    <input class="form-check-input" type="radio" name="paymentMethod" id="boleto" value="boleto">
                    <label class="form-check-label" for="boleto">
                      <i class="bi bi-upc-scan me-2"></i>Boleto Bancário
                    </label>
                  </div>
                </div>

                <!-- Campos do Cartão de Crédito -->
                <div id="creditCardFields">
                  <div class="col-12 mb-3">
                    <label for="cardNumber" class="form-label">Número do Cartão *</label>
                    <input type="text" class="form-control" id="cardNumber" placeholder="1234 5678 9012 3456"
                      maxlength="18">
                  </div>
                  <div class="row">
                    <div class="col-md-6 mb-3">
                      <label for="expiryDate" class="form-label">Data de Validade *</label>
                      <input type="text" class="form-control" maxlength="5" id="expiryDate" placeholder="MM/AA">
                    </div>
                    <div class="col-md-6 mb-3">
                      <label for="cvv" class="form-label">CVV *</label>
                      <input type="text" class="form-control" id="cvv" placeholder="123">
                    </div>
                  </div>
                  <div class="col-12 mb-3">
                    <label for="cardName" class="form-label">Nome no Cartão *</label>
                    <input type="text" class="form-control" id="cardName">
                  </div>
                </div>
              </div>

              <!-- Botões -->
              <div class="row">
                <div class="col-12">
                  <button type="submit" class="btn btn-primary btn-lg w-100">
                    <i class="bi bi-lock me-2"></i>Finalizar Compra
                  </button>
                  <a href="/produtos" class="btn btn-outline-secondary w-100 mt-2">
                    <i class="bi bi-arrow-left me-2"></i>Voltar aos Produtos
                  </a>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <!-- Resumo do Pedido -->
        <div class="card shadow-sm sticky-top" style="top: 2rem; border-radius: 20px; border: none;">
          <div class="card-header"
            style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-radius: 20px 20px 0 0; border: none;">
            <h5 class="mb-0"><i class="bi bi-cart-check me-2"></i>Resumo do Pedido</h5>
          </div>
          <div class="card-body">
            <div id="orderSummary">
              <!-- Resumo será carregado dinamicamente -->
            </div>

            <div class="border-top pt-3">
              <div class="d-flex justify-content-between mb-2">
                <span>Subtotal:</span>
                <span id="subtotal">R$ 0,00</span>
              </div>
              <div class="d-flex justify-content-between mb-2">
                <span>Frete:</span>
                <span id="shipping">R$ 0,00</span>
              </div>
              <div class="d-flex justify-content-between mb-2">
                <span>Taxas:</span>
                <span id="taxes">R$ 0,00</span>
              </div>
              <div class="border-top pt-2">
                <div class="d-flex justify-content-between">
                  <strong>Total:</strong>
                  <strong id="total" class="text-primary">R$ 0,00</strong>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>


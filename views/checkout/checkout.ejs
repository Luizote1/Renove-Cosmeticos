<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Renove | Finalizar Compra</title>

  <link rel="icon" href="/img/logo.png">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/bootstrap.css">
  <link rel="stylesheet" href="/css/themes.css?v=120">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

  <style>
    .navbar {
      position: relative;
      z-index: 99999 !important;
    }

    .dropdown-menu {
      z-index: 100000 !important;
    }

    .checkout-wrapper {
      max-width: 1280px;
      margin: 0 auto;
      padding-left: 22px;
      padding-right: 22px;
    }

    .checkout-card,
    .checkout-summary-card {
      border-radius: 22px;
      border: none;
      overflow: hidden;
      position: relative;
      z-index: 1;
    }

    .checkout-card-header {
      min-height: 58px;
      display: flex;
      align-items: center;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      border: none;
    }

    .checkout-form .form-control,
    .checkout-form .form-select {
      height: 52px;
      border: 2px solid #dbe3ef;
      border-radius: 12px;
      background: #ffffff;
      font-size: 16px;
    }

    .checkout-form .form-control:focus,
    .checkout-form .form-select:focus {
      border-color: #667eea;
      box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.18);
    }

    .checkout-form label {
      font-weight: 600;
      color: #2c3e50;
      margin-bottom: 7px;
    }

    .checkout-summary-card {
      top: 24px;
    }

    @media (max-width: 991px) {
      .checkout-wrapper {
        padding-left: 16px;
        padding-right: 16px;
      }

      .checkout-summary-card {
        position: static !important;
        margin-top: 18px;
      }
    }

    @media (max-width: 768px) {
      .checkout-wrapper {
        padding-left: 14px;
        padding-right: 14px;
      }

      .checkout-wrapper .row {
        margin-left: 0;
        margin-right: 0;
      }

      .checkout-wrapper .col-lg-8,
      .checkout-wrapper .col-lg-4,
      .checkout-wrapper .col-md-4,
      .checkout-wrapper .col-md-6,
      .checkout-wrapper .col-md-8,
      .checkout-wrapper .col-12 {
        padding-left: 0;
        padding-right: 0;
      }

      .checkout-card .card-body,
      .checkout-summary-card .card-body {
        padding: 22px;
      }

      .checkout-title {
        font-size: 1.25rem;
      }

      .checkout-card-header h4,
      .checkout-card-header h5 {
        font-size: 1.1rem;
      }

      .checkout-form .form-control,
      .checkout-form .form-select {
        height: 56px;
        font-size: 16px;
      }

      #creditCardFields .row {
        margin-left: 0;
        margin-right: 0;
      }

      #creditCardFields .row>div {
        padding-left: 0;
        padding-right: 0;
      }
    }

    .payment-method-toggle {
      display: flex;
      flex-direction: column;
      gap: 14px;
      margin-top: 8px;
    }

    .payment-method-toggle .form-check {
      display: flex;
      align-items: center;
      gap: 12px;
      padding-left: 0;
      margin-bottom: 0;
    }

    .payment-method-toggle .form-check-input {
      width: 18px !important;
      height: 18px !important;
      min-width: 18px !important;
      margin: 0 !important;
      padding: 0 !important;
      border: 1px solid #b8c7db !important;
      border-radius: 50% !important;
      appearance: auto !important;
      -webkit-appearance: radio !important;
      box-shadow: none !important;
      transform: none !important;
    }

    .payment-method-toggle .form-check-label {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 1rem;
      color: #2c3e50;
      cursor: pointer;
    }

    .payment-method-toggle i {
      color: #4f7bce;
      font-size: 1rem;
    }

  </style>
</head>

<body class="theme-light">

  <!-- LOADING -->
  <div id="loadingOverlay" class="loading-overlay">
    <svg class="pill-loader-svg" viewBox="0 0 100 30" xmlns="http://www.w3.org/2000/svg">
      <path class="pill-half-filled" d="M50 0 L15 0 A15 15 0 0 0 15 30 L50 30 Z" />
      <path class="pill-half-outline" d="M50 0 L85 0 A15 15 0 0 1 85 30 L50 30 Z" />
    </svg>
  </div>

  <!-- NAVBAR SEM CARRINHO -->
  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid">

      <a class="navbar-brand" href="/">
        <img class="images" src="/img/logotipo.png" alt="Renove">
      </a>

      <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarTogglerDemo02">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarTogglerDemo02">

        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">

          <li class="nav-item">
            <a class="nav-link" href="/">Início</a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/produtos">Produtos</a>
          </li>

          <% if(!usuarioLogado){ %>

            <li class="nav-item">
              <a class="nav-link" href="/cadastro">Registrar</a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/login">Login</a>
            </li>

          <% } else { %>

            <li class="nav-item dropdown">

              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                <i class="bi bi-person-circle"></i>
                Minha Conta
              </a>

              <ul class="dropdown-menu dropdown-menu-end">

                <li>
                  <a class="dropdown-item" href="/perfil">
                    <i class="bi bi-person"></i>
                    Meu Perfil
                  </a>
                </li>

                <li>
                  <a class="dropdown-item" href="/pedido/meus-pedidos">
                    <i class="bi bi-bag-check"></i>
                    Meus Pedidos
                  </a>
                </li>

                <% if(tipoLogado == "usuario"){ %>
                  <li>
                    <a class="dropdown-item" href="/usuario">
                      <i class="bi bi-gear"></i>
                      Sistema
                    </a>
                  </li>
                <% } %>

                <li>
                  <hr class="dropdown-divider">
                </li>

                <li>
                  <button class="dropdown-item text-danger" type="button" onclick="window.location='/login/logout'">
                    <i class="bi bi-box-arrow-right"></i>
                    Sair
                  </button>
                </li>

              </ul>

            </li>

          <% } %>

        </ul>

      </div>

    </div>
  </nav>

  <!-- CONTEÚDO CHECKOUT -->
  <div class="checkout-wrapper mt-4 mb-5">

    <div class="row g-4 align-items-start">

      <div class="col-lg-8">

        <div class="card shadow-sm checkout-card">

          <div class="card-header checkout-card-header">
            <h4 class="mb-0 checkout-title">
              <i class="bi bi-credit-card me-2"></i>
              Informações de Pagamento
            </h4>
          </div>

          <div class="card-body p-4">

            <form id="checkoutForm" class="checkout-form">

              <!-- ENDEREÇO -->
              <div class="row mb-4">

                <div class="col-12">
                  <h5 class="border-bottom pb-2 mb-3">
                    Endereço de Entrega
                  </h5>
                </div>

                <div class="col-md-4 mb-3">
                  <label for="zipCode" class="form-label">CEP *</label>
                  <input type="text" class="form-control" maxlength="9" id="zipCode" required>
                </div>

                <div class="col-md-4 mb-3">
                  <label for="cidade" class="form-label">Cidade *</label>
                  <input type="text" class="form-control" id="cidade" required>
                </div>

                <div class="col-md-4 mb-3">
                  <label for="estado" class="form-label">Estado *</label>
                  <input type="text" class="form-control" id="estado" required>
                </div>

                <div class="col-12 mb-3">
                  <label for="rua" class="form-label">Rua *</label>
                  <input type="text" class="form-control" id="rua" required>
                </div>

                <div class="col-12 mb-3">
                  <label for="bairro" class="form-label">Bairro *</label>
                  <input type="text" class="form-control" id="bairro" required>
                </div>

                <div class="col-md-4 mb-3">
                  <label for="numero" class="form-label">Número *</label>
                  <input type="number" class="form-control" id="numero" required>
                </div>

                <div class="col-md-8 mb-3">
                  <label for="complemento" class="form-label">Complemento opcional</label>
                  <input type="text" class="form-control" id="complemento">
                </div>

              </div>

              <!-- PAGAMENTO -->
              <div class="row mb-4">

                <div class="col-12">
                  <h5 class="border-bottom pb-2 mb-3">
                    Método de Pagamento
                  </h5>
                </div>

                <div class="col-12 mb-3">

                  <div class="payment-method-toggle">

                    <div class="form-check">
                      <input class="form-check-input" type="radio" name="paymentMethod" id="creditCard" value="credit" checked>
                      <label class="form-check-label" for="creditCard">
                        <i class="bi bi-credit-card"></i>
                        Cartão de Crédito
                      </label>
                    </div>

                    <div class="form-check">
                      <input class="form-check-input" type="radio" name="paymentMethod" id="pix" value="pix">
                      <label class="form-check-label" for="pix">
                        <i class="bi bi-qr-code"></i>
                        PIX
                      </label>
                    </div>

                    <div class="form-check">
                      <input class="form-check-input" type="radio" name="paymentMethod" id="boleto" value="boleto">
                      <label class="form-check-label" for="boleto">
                        <i class="bi bi-receipt"></i>
                        Boleto Bancário
                      </label>
                    </div>

                  </div>

                </div>

                <!-- CARTÃO -->
                <div id="creditCardFields">

                  <div class="col-12 mb-3">
                    <label for="cardNumber" class="form-label">Número do Cartão *</label>
                    <input type="text" class="form-control" id="cardNumber" placeholder="1234 5678 9012 3456" maxlength="18">
                  </div>

                  <div class="row">

                    <div class="col-md-6 mb-3">
                      <label for="expiryDate" class="form-label">Data de Validade *</label>
                      <input type="text" class="form-control" maxlength="5" id="expiryDate" placeholder="MM/AA">
                    </div>

                    <div class="col-md-6 mb-3">
                      <label for="cvv" class="form-label">CVV *</label>
                      <input type="text" class="form-control" id="cvv" placeholder="123">
                    </div>

                  </div>

                  <div class="col-12 mb-3">
                    <label for="cardName" class="form-label">Nome no Cartão *</label>
                    <input type="text" class="form-control" id="cardName">
                  </div>

                </div>

              </div>

              <!-- BOTÕES -->
              <div class="row">
                <div class="col-12">

                  <button type="submit" class="btn btn-primary btn-lg w-100">
                    <i class="bi bi-lock me-2"></i>
                    Finalizar Compra
                  </button>

                  <a href="/produtos" class="btn btn-outline-secondary w-100 mt-2">
                    <i class="bi bi-arrow-left me-2"></i>
                    Voltar aos Produtos
                  </a>

                </div>
              </div>

            </form>

          </div>

        </div>

      </div>

      <!-- RESUMO -->
      <div class="col-lg-4">

        <div class="card shadow-sm sticky-top checkout-summary-card">

          <div class="card-header checkout-card-header">
            <h5 class="mb-0">
              <i class="bi bi-cart-check me-2"></i>
              Resumo do Pedido
            </h5>
          </div>

          <div class="card-body p-4">

            <div id="orderSummary">
              <!-- Resumo será carregado dinamicamente -->
            </div>

            <div class="border-top pt-3">

              <div class="d-flex justify-content-between mb-2">
                <span>Subtotal:</span>
                <span id="subtotal">R$ 0,00</span>
              </div>

              <div class="d-flex justify-content-between mb-2">
                <span>Frete:</span>
                <span id="shipping">R$ 0,00</span>
              </div>

              <div class="d-flex justify-content-between mb-2">
                <span>Taxas:</span>
                <span id="taxes">R$ 0,00</span>
              </div>

              <div class="border-top pt-2">
                <div class="d-flex justify-content-between">
                  <strong>Total:</strong>
                  <strong id="total" class="text-primary">R$ 0,00</strong>
                </div>
              </div>

            </div>

          </div>

        </div>

      </div>

    </div>

  </div>

  <!-- FOOTER -->
  <footer class="footer-techmode">

    <div class="footer-container">

      <div class="footer-coluna" id="footer-logo-col">
        <img src="/img/logo.png" alt="Logo Renove" class="footer-logo">
        <p class="footer-slogan">Inovação e tecnologia ao seu alcance.</p>
      </div>

      <div class="footer-coluna">
        <h4>Empresa</h4>

        <ul>
          <li><a href="#">Sobre Nós</a></li>
          <li><a href="#">Carreiras</a></li>
          <li><a href="#">Imprensa</a></li>
          <li><a href="#">Contato</a></li>
        </ul>
      </div>

      <div class="footer-coluna">
        <h4>Suporte</h4>

        <ul>
          <li><a href="#">FAQ</a></li>
          <li><a href="#">Central de Ajuda</a></li>
          <li><a href="#">Termos de Serviço</a></li>
          <li><a href="#">Política de Privacidade</a></li>
        </ul>
      </div>

      <div class="footer-coluna">
        <h4>Siga-nos</h4>

        <div class="footer-social-links">

          <a href="#" aria-label="Facebook" title="Facebook">
            <i class="bi bi-facebook"></i>
          </a>

          <a href="#" aria-label="Instagram" title="Instagram">
            <i class="bi bi-instagram"></i>
          </a>

          <a href="#" aria-label="Twitter" title="Twitter">
            <i class="bi bi-twitter-x"></i>
          </a>

        </div>
      </div>

    </div>

    <div class="footer-bottom-bar">
      <p>
        &copy; 2025 Tech Mode. Todos os direitos reservados.
        Desenvolvido por
        <a href="https://luizote1.github.io/tech-mode/" target="_blank" rel="noopener noreferrer">
          Tech Mode
        </a>.
      </p>
    </div>

  </footer>

  <!-- VLIBRAS -->
  <div vw class="enabled">
    <div vw-access-button class="active"></div>

    <div vw-plugin-wrapper>
      <div class="vw-plugin-top-wrapper"></div>
    </div>
  </div>

  <script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>

  <script>
    new window.VLibras.Widget('https://vlibras.gov.br/app');
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/checkout.js"></script>
  <script src="/js/site.js"></script>

</body>

</html>

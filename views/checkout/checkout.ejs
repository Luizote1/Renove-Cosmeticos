<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Renove | Finalizar Compra</title>

  <link rel="icon" href="/img/logo.png">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

  <link rel="stylesheet" href="/css/bootstrap.css">
  <link rel="stylesheet" href="/css/themes.css?v=90">

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

  <style>
    .navbar {
      position: relative;
      z-index: 99999 !important;
    }

    .dropdown-menu {
      z-index: 100000 !important;
    }

    .sticky-top {
      z-index: 1 !important;
    }

    .card {
      position: relative;
      z-index: 1;
    }

    @media (max-width: 768px) {
      .checkout-title {
        font-size: 1.35rem;
      }

      .checkout-card-header h4,
      .checkout-card-header h5 {
        font-size: 1rem;
      }

      .container {
        padding-left: 14px;
        padding-right: 14px;
      }

      .card-body {
        padding: 1rem;
      }

      #creditCardFields .row {
        margin-left: 0;
        margin-right: 0;
      }

      #creditCardFields .row>div {
        padding-left: 0;
        padding-right: 0;
      }

      .sticky-top {
        position: static !important;
        margin-top: 20px;
      }
    }
  </style>
</head>

<body class="theme-light">

  <!-- LOADING -->
  <div id="loadingOverlay" class="loading-overlay">
    <svg class="pill-loader-svg" viewBox="0 0 100 30" xmlns="http://www.w3.org/2000/svg">
      <path class="pill-half-filled" d="M50 0 L15 0 A15 15 0 0 0 15 30 L50 30 Z" />
      <path class="pill-half-outline" d="M50 0 L85 0 A15 15 0 0 1 85 30 L50 30 Z" />
    </svg>
  </div>

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid">

      <!-- LOGO -->
      <a class="navbar-brand" href="/">
        <img class="images" src="/img/logotipo.png" alt="Renove">
      </a>

      <!-- MOBILE RIGHT -->
      <div class="d-flex align-items-center gap-2 ms-auto d-lg-none">

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarTogglerDemo02">
          <span class="navbar-toggler-icon"></span>
        </button>

        <button class="btn cart-navbar-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#cartOffcanvas">
          <i class="bi bi-cart3"></i>
          <span class="cart-navbar-count" id="cartCountMobile">0</span>
        </button>

      </div>

      <!-- MENU COLLAPSE -->
      <div class="collapse navbar-collapse" id="navbarTogglerDemo02">

        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">

          <li class="nav-item">
            <a class="nav-link" href="/">Início</a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/produtos">Produtos</a>
          </li>

          <% if(!usuarioLogado){ %>

            <li class="nav-item">
              <a class="nav-link" href="/cadastro">Registrar</a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/login">Login</a>
            </li>

          <% } else { %>

            <li class="nav-item dropdown">

              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                <i class="bi bi-person-circle"></i>
                Minha Conta
              </a>

              <ul class="dropdown-menu dropdown-menu-end">

                <li>
                  <a class="dropdown-item" href="/perfil">
                    <i class="bi bi-person"></i>
                    Meu Perfil
                  </a>
                </li>

                <li>
                  <a class="dropdown-item" href="/pedido/meus-pedidos">
                    <i class="bi bi-bag-check"></i>
                    Meus Pedidos
                  </a>
                </li>

                <% if(tipoLogado=="usuario"){ %>

                  <li>
                    <a class="dropdown-item" href="/usuario">
                      <i class="bi bi-gear"></i>
                      Sistema
                    </a>
                  </li>

                <% } %>

                <li>
                  <hr class="dropdown-divider">
                </li>

                <li>
                  <button class="dropdown-item text-danger" type="button" onclick="window.location='/login/logout'">
                    <i class="bi bi-box-arrow-right"></i>
                    Sair
                  </button>
                </li>

              </ul>

            </li>

          <% } %>

        </ul>

        <!-- DESKTOP CARRINHO -->
        <div class="d-none d-lg-flex ms-3">

          <button class="btn cart-navbar-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#cartOffcanvas">
            <i class="bi bi-cart3"></i>
            <span class="cart-navbar-count" id="cartCount">0</span>
          </button>

        </div>

      </div>

    </div>
  </nav>

  <!-- CONTEÚDO CHECKOUT -->
  <div class="container mt-4 mb-5">

    <div class="row g-4">

      <div class="col-lg-8">

        <div class="card shadow-sm" style="border-radius: 20px; border: none;">

          <div class="card-header checkout-card-header"
            style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-radius: 20px 20px 0 0; border: none;">
            <h4 class="mb-0 checkout-title">
              <i class="bi bi-credit-card me-2"></i>
              Informações de Pagamento
            </h4>
          </div>

          <div class="card-body">

            <form id="checkoutForm">

              <!-- ENDEREÇO -->
              <div class="row mb-4">

                <div class="col-12">
                  <h5 class="border-bottom pb-2 mb-3">
                    Endereço de Entrega
                  </h5>
                </div>

                <div class="col-md-4 mb-3">
                  <label for="zipCode" class="form-label">CEP *</label>
                  <input type="text" class="form-control" maxlength="9" id="zipCode" required>
                </div>

                <div class="col-md-4 mb-3">
                  <label for="cidade" class="form-label">Cidade *</label>
                  <input type="text" class="form-control" id="cidade" required>
                </div>

                <div class="col-md-4 mb-3">
                  <label for="estado" class="form-label">Estado *</label>
                  <input type="text" class="form-control" id="estado" required>
                </div>

                <div class="col-12 mb-3">
                  <label for="rua" class="form-label">Rua *</label>
                  <input type="text" class="form-control" id="rua" required>
                </div>

                <div class="col-12 mb-3">
                  <label for="bairro" class="form-label">Bairro *</label>
                  <input type="text" class="form-control" id="bairro" required>
                </div>

                <div class="col-md-4 mb-3">
                  <label for="numero" class="form-label">Número *</label>
                  <input type="number" class="form-control" id="numero" required>
                </div>

                <div class="col-md-8 mb-3">
                  <label for="complemento" class="form-label">Complemento opcional</label>
                  <input type="text" class="form-control" id="complemento">
                </div>

              </div>

              <!-- PAGAMENTO -->
              <div class="row mb-4">

                <div class="col-12">
                  <h5 class="border-bottom pb-2 mb-3">
                    Método de Pagamento
                  </h5>
                </div>

                <div class="col-12 mb-3">

                  <div class="form-check">
                    <input class="form-check-input" type="radio" name="paymentMethod" id="creditCard" value="credit"
                      checked>
                    <label class="form-check-label" for="creditCard">
                      <i class="bi bi-credit-card me-2"></i>
                      Cartão de Crédito
                    </label>
                  </div>

                  <div class="form-check">
                    <input class="form-check-input" type="radio" name="paymentMethod" id="pix" value="pix">
                    <label class="form-check-label" for="pix">
                      <i class="bi bi-qr-code me-2"></i>
                      PIX
                    </label>
                  </div>

                  <div class="form-check">
                    <input class="form-check-input" type="radio" name="paymentMethod" id="boleto" value="boleto">
                    <label class="form-check-label" for="boleto">
                      <i class="bi bi-upc-scan me-2"></i>
                      Boleto Bancário
                    </label>
                  </div>

                </div>

                <!-- CARTÃO -->
                <div id="creditCardFields">

                  <div class="col-12 mb-3">
                    <label for="cardNumber" class="form-label">Número do Cartão *</label>
                    <input type="text" class="form-control" id="cardNumber" placeholder="1234 5678 9012 3456"
                      maxlength="18">
                  </div>

                  <div class="row">

                    <div class="col-md-6 mb-3">
                      <label for="expiryDate" class="form-label">Data de Validade *</label>
                      <input type="text" class="form-control" maxlength="5" id="expiryDate" placeholder="MM/AA">
                    </div>

                    <div class="col-md-6 mb-3">
                      <label for="cvv" class="form-label">CVV *</label>
                      <input type="text" class="form-control" id="cvv" placeholder="123">
                    </div>

                  </div>

                  <div class="col-12 mb-3">
                    <label for="cardName" class="form-label">Nome no Cartão *</label>
                    <input type="text" class="form-control" id="cardName">
                  </div>

                </div>

              </div>

              <!-- BOTÕES -->
              <div class="row">
                <div class="col-12">

                  <button type="submit" class="btn btn-primary btn-lg w-100">
                    <i class="bi bi-lock me-2"></i>
                    Finalizar Compra
                  </button>

                  <a href="/produtos" class="btn btn-outline-secondary w-100 mt-2">
                    <i class="bi bi-arrow-left me-2"></i>
                    Voltar aos Produtos
                  </a>

                </div>
              </div>

            </form>

          </div>

        </div>

      </div>

      <!-- RESUMO -->
      <div class="col-lg-4">

        <div class="card shadow-sm sticky-top" style="top: 2rem; border-radius: 20px; border: none;">

          <div class="card-header checkout-card-header"
            style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-radius: 20px 20px 0 0; border: none;">
            <h5 class="mb-0">
              <i class="bi bi-cart-check me-2"></i>
              Resumo do Pedido
            </h5>
          </div>

          <div class="card-body">

            <div id="orderSummary">
              <!-- Resumo será carregado dinamicamente -->
            </div>

            <div class="border-top pt-3">

              <div class="d-flex justify-content-between mb-2">
                <span>Subtotal:</span>
                <span id="subtotal">R$ 0,00</span>
              </div>

              <div class="d-flex justify-content-between mb-2">
                <span>Frete:</span>
                <span id="shipping">R$ 0,00</span>
              </div>

              <div class="d-flex justify-content-between mb-2">
                <span>Taxas:</span>
                <span id="taxes">R$ 0,00</span>
              </div>

              <div class="border-top pt-2">
                <div class="d-flex justify-content-between">
                  <strong>Total:</strong>
                  <strong id="total" class="text-primary">R$ 0,00</strong>
                </div>
              </div>

            </div>

          </div>

        </div>

      </div>

    </div>

  </div>

  <!-- CARRINHO -->
  <div class="offcanvas offcanvas-end cart-panel" tabindex="-1" id="cartOffcanvas">

    <div class="offcanvas-header border-bottom">

      <div class="d-flex align-items-center gap-2">
        <i class="bi bi-cart3 fs-4 text-primary"></i>

        <div>
          <h5 class="mb-0 fw-bold">Seu Carrinho</h5>
          <small class="text-muted">Seus produtos selecionados</small>
        </div>
      </div>

      <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>

    </div>

    <div class="offcanvas-body">

      <div id="cartItems">
        <div class="text-center py-4">
          <i class="bi bi-cart3 display-4 text-muted"></i>
          <p class="mt-2 text-muted">Seu carrinho está vazio</p>
        </div>
      </div>

      <div class="cart-footer">

        <div class="d-flex justify-content-between mb-2">
          <span>Subtotal</span>
          <strong id="cartSubtotal">R$ 0,00</strong>
        </div>

        <div class="d-flex justify-content-between mb-3">
          <span>Frete</span>
          <strong>Grátis</strong>
        </div>

        <hr>

        <div class="d-flex justify-content-between fs-5">
          <strong>Total</strong>
          <strong class="text-primary" id="cartTotal">R$ 0,00</strong>
        </div>

        <button class="btn btn-primary w-100 mt-4 py-3" onclick="window.location.href='/checkout'">
          <i class="bi bi-credit-card me-2"></i>
          Finalizar Compra
        </button>

      </div>

    </div>

  </div>

  <!-- FOOTER -->
  <footer class="footer-techmode">

    <div class="footer-container">

      <div class="footer-coluna" id="footer-logo-col">
        <img src="/img/logo.png" alt="Logo Renove" class="footer-logo">
        <p class="footer-slogan">Inovação e tecnologia ao seu alcance.</p>
      </div>

      <div class="footer-coluna">
        <h4>Empresa</h4>

        <ul>
          <li><a href="#">Sobre Nós</a></li>
          <li><a href="#">Carreiras</a></li>
          <li><a href="#">Imprensa</a></li>
          <li><a href="#">Contato</a></li>
        </ul>
      </div>

      <div class="footer-coluna">
        <h4>Suporte</h4>

        <ul>
          <li><a href="#">FAQ</a></li>
          <li><a href="#">Central de Ajuda</a></li>
          <li><a href="#">Termos de Serviço</a></li>
          <li><a href="#">Política de Privacidade</a></li>
        </ul>
      </div>

      <div class="footer-coluna">
        <h4>Siga-nos</h4>

        <div class="footer-social-links">

          <a href="#" aria-label="Facebook" title="Facebook">
            <i class="bi bi-facebook"></i>
          </a>

          <a href="#" aria-label="Instagram" title="Instagram">
            <i class="bi bi-instagram"></i>
          </a>

          <a href="#" aria-label="Twitter" title="Twitter">
            <i class="bi bi-twitter-x"></i>
          </a>

        </div>
      </div>

    </div>

    <div class="footer-bottom-bar">
      <p>
        &copy; 2025 Tech Mode. Todos os direitos reservados.
        Desenvolvido por
        <a href="https://luizote1.github.io/tech-mode/" target="_blank" rel="noopener noreferrer">
          Tech Mode
        </a>.
      </p>
    </div>

  </footer>

  <!-- VLIBRAS -->
  <div vw class="enabled">
    <div vw-access-button class="active"></div>

    <div vw-plugin-wrapper>
      <div class="vw-plugin-top-wrapper"></div>
    </div>
  </div>

  <script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>

  <script>
    new window.VLibras.Widget('https://vlibras.gov.br/app');
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/checkout.js"></script>
  <script src="/js/site.js"></script>

  <script>
    document.addEventListener("DOMContentLoaded", function () {

      function formatarMoeda(valor) {
        return "R$ " + Number(valor).toFixed(2).replace(".", ",");
      }

      function carregarCarrinhoNavbar() {
        let carrinho = [];

        try {
          carrinho = JSON.parse(localStorage.getItem("cart")) || [];
        } catch (erro) {
          carrinho = [];
        }

        const totalItens = carrinho.reduce((soma, item) => soma + Number(item.quantity || 0), 0);
        const subtotal = carrinho.reduce((soma, item) => soma + (Number(item.price || 0) * Number(item.quantity || 0)), 0);

        const cartCount = document.getElementById("cartCount");
        const cartCountMobile = document.getElementById("cartCountMobile");
        const cartItems = document.getElementById("cartItems");
        const cartSubtotal = document.getElementById("cartSubtotal");
        const cartTotal = document.getElementById("cartTotal");

        if (cartCount) cartCount.textContent = totalItens;
        if (cartCountMobile) cartCountMobile.textContent = totalItens;

        if (cartSubtotal) cartSubtotal.textContent = formatarMoeda(subtotal);
        if (cartTotal) cartTotal.textContent = formatarMoeda(subtotal);

        if (!cartItems) return;

        if (carrinho.length === 0) {
          cartItems.innerHTML = `
            <div class="text-center py-4">
              <i class="bi bi-cart3 display-4 text-muted"></i>
              <p class="mt-2 text-muted">Seu carrinho está vazio</p>
            </div>
          `;
          return;
        }

        cartItems.innerHTML = carrinho.map(item => `
          <div class="cart-item">
            <div class="d-flex align-items-center gap-3">
              <img src="${item.image || "/img/produtos/produto-sem-imagem.png"}" alt="${item.name || "Produto"}">

              <div class="flex-grow-1">
                <h6>${item.name || "Produto"}</h6>

                <p>${formatarMoeda(item.price || 0)}</p>

                <small class="text-muted">
                  Qtd: ${item.quantity || 1}
                </small>
              </div>
            </div>
          </div>
        `).join("");
      }

      carregarCarrinhoNavbar();
    });
  </script>

</body>

</html>
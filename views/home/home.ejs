<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Renove | Farmácia de Cosméticos</title>

  <link rel="icon" href="/img/logo.png">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">

  <link rel="stylesheet" href="/css/bootstrap.css">
  <link rel="stylesheet" href="/css/themes.css?v=90">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

  <style>
    .hero {
      border-radius: 25px;
      padding: 6rem;
      margin: 2rem auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: relative;
      overflow: hidden;
      z-index: 1;
      background-color: #ffffff00;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg,
          rgba(102, 126, 234, .1) 0%,
          rgba(118, 75, 162, .1) 100%);
      z-index: 1;
      pointer-events: none;
    }

    .hero-text,
    .hero-img {
      position: relative;
      z-index: 2;
    }

    .hero-text {
      max-width: 50%;
    }

    .hero h1 {
      font-weight: 800;
      font-size: 3.5rem;
      line-height: 1.2;
      margin-bottom: 1.5rem;
    }

    .hero p {
      font-size: 1.3rem;
      line-height: 1.6;
      margin-bottom: 2rem;
      opacity: .9;
    }

    .navbar {
      position: relative;
      z-index: 1040;
    }

    .dropdown-menu {
      z-index: 1050 !important;
    }

    .offcanvas {
      z-index: 1080 !important;
    }

    .offcanvas-backdrop {
      z-index: 1070 !important;
    }

    .card {
      border-radius: 20px;
      overflow: hidden;
      transition: all .4s cubic-bezier(.4, 0, .2, 1);
    }

    .card-img-top {
      max-height: 200px;
      object-fit: contain;
      padding: 1.5rem;
      transition: all .4s ease;
    }

    .card:hover .card-img-top {
      transform: scale(1.05);
    }

    @media (max-width: 768px) {
      .hero {
        padding: 2rem 1rem;
        margin: 1rem;
        flex-direction: column;
        text-align: center;
      }

      .hero-text {
        max-width: 100%;
      }

      .hero h1 {
        font-size: 2.2rem;
      }

      .hero p {
        font-size: 1rem;
      }

      .hero-img {
        margin-top: 1.5rem;
      }
    }
  </style>
</head>

<body class="theme-light">

  <!-- LOADING -->
  <div id="loadingOverlay" class="loading-overlay">
    <svg class="pill-loader-svg" viewBox="0 0 100 30" xmlns="http://www.w3.org/2000/svg">
      <path class="pill-half-filled" d="M50 0 L15 0 A15 15 0 0 0 15 30 L50 30 Z" />
      <path class="pill-half-outline" d="M50 0 L85 0 A15 15 0 0 1 85 30 L50 30 Z" />
    </svg>
  </div>

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid">

      <!-- LOGO -->
      <a class="navbar-brand" href="/">
        <img class="images" src="/img/logotipo.png" alt="Renove">
      </a>

      <!-- MOBILE RIGHT -->
      <div class="d-flex align-items-center gap-2 ms-auto d-lg-none">

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarTogglerDemo02">
          <span class="navbar-toggler-icon"></span>
        </button>

        <button class="btn cart-navbar-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#cartOffcanvas">
          <i class="bi bi-cart3"></i>
          <span class="cart-navbar-count" id="cartCountMobile">0</span>
        </button>

      </div>

      <!-- MENU -->
      <div class="collapse navbar-collapse" id="navbarTogglerDemo02">

        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">

          <li class="nav-item">
            <a class="nav-link active" href="/">Início</a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/produtos">Produtos</a>
          </li>

          <% if(!usuarioLogado){ %>

            <li class="nav-item">
              <a class="nav-link" href="/cadastro">Registrar</a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/login">Login</a>
            </li>

            <% } else { %>

              <li class="nav-item dropdown">

                <a class="nav-link dropdown-toggle" href="#" id="menuConta" role="button" data-bs-toggle="dropdown"
                  aria-expanded="false">
                  <i class="bi bi-person-circle"></i>
                  Minha Conta
                </a>

                <ul class="dropdown-menu dropdown-menu-end">

                  <li>
                    <a class="dropdown-item" href="/perfil">
                      <i class="bi bi-person"></i>
                      Meu Perfil
                    </a>
                  </li>

                  <li>
                    <a class="dropdown-item" href="/pedido/meus-pedidos">
                      <i class="bi bi-bag-check"></i>
                      Meus Pedidos
                    </a>
                  </li>

                  <% if(tipoLogado=="usuario" ){ %>
                    <li>
                      <a class="dropdown-item" href="/usuario">
                        <i class="bi bi-gear"></i>
                        Sistema
                      </a>
                    </li>
                    <% } %>

                      <li>
                        <hr class="dropdown-divider">
                      </li>

                      <li>
                        <button class="dropdown-item text-danger" type="button"
                          onclick="window.location='/login/logout'">
                          <i class="bi bi-box-arrow-right"></i>
                          Sair
                        </button>
                      </li>

                </ul>

              </li>

              <% } %>

        </ul>

        <!-- DESKTOP CARRINHO -->
        <div class="d-none d-lg-flex ms-3">
          <button class="btn cart-navbar-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#cartOffcanvas">
            <i class="bi bi-cart3"></i>
            <span class="cart-navbar-count" id="cartCount">0</span>
          </button>
        </div>

      </div>

    </div>
  </nav>

  <!-- HERO -->
  <section class="hero container">

    <div class="hero-text">
      <h1>Cuide de você com a <span>Renove</span></h1>
      <p>Os melhores cosméticos e cuidados para você</p>
      <a href="/produtos" class="btn btn-primary btn-lg">Ver Produtos</a>
    </div>

    <div class="hero-img">
      <img src="/img/banner.png" alt="Produtos Renove" class="img-fluid rounded">
    </div>

  </section>

  <!-- PRODUTOS EM DESTAQUE -->
  <div class="container my-5">

    <h2 class="text-center mb-4">Produtos em Destaque</h2>

    <div class="row g-4">

      <% if (produtosDestaque && produtosDestaque.length> 0) { %>

        <% produtosDestaque.forEach(produto=> { %>

          <div class="col-md-4">

            <div class="card shadow-sm h-100 text-center">

              <img src="<%= produto.proImagem ? produto.proImagem : '/img/produtos/produto-sem-imagem.png' %>"
                class="card-img-top mx-auto" alt="<%= produto.proNome %>">

              <div class="card-body">

                <h5 class="card-title">
                  <%= produto.proNome %>
                </h5>

                <p class="card-text">
                  <%= produto.proDescricao || 'Produto em destaque da Renove.' %>
                </p>

                <h5 class="text-primary">
                  R$ <%= Number(produto.proPreco).toFixed(2).replace(".", "," ) %>
                </h5>

                <a href="/produtos" class="btn btn-outline-primary">
                  Ver Produto
                </a>

              </div>

            </div>

          </div>

          <% }) %>

            <% } else { %>

              <div class="col-12 text-center">
                <p class="text-muted">Nenhum produto em destaque disponível.</p>
              </div>

              <% } %>

    </div>

  </div>

  <!-- MODAL PRODUTO -->
  <div class="modal fade product-modal" id="productModal" tabindex="-1" aria-labelledby="productModalLabel"
    aria-hidden="true">

    <div class="modal-dialog modal-lg">

      <div class="modal-content">

        <div class="modal-header">

          <h5 class="modal-title" id="productModalLabel">
            Detalhes do Produto
          </h5>

          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>

        </div>

        <div class="modal-body" id="productModalBody"></div>

      </div>

    </div>

  </div>

  <!-- CARRINHO PREMIUM -->
  <div class="offcanvas offcanvas-end cart-panel" tabindex="-1" id="cartOffcanvas">

    <div class="offcanvas-header border-bottom">

      <div class="d-flex align-items-center gap-2">

        <i class="bi bi-cart3 fs-4 text-primary"></i>

        <div>
          <h5 class="mb-0 fw-bold">Seu Carrinho</h5>
          <small class="text-muted">Seus produtos selecionados</small>
        </div>

      </div>

      <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>

    </div>

    <div class="offcanvas-body">

      <div id="cartItems"></div>

      <div class="cart-footer">

        <div class="d-flex justify-content-between mb-3">
          <span>Frete</span>
          <strong>Grátis</strong>
        </div>

        <hr>

        <div class="d-flex justify-content-between fs-5">
          <strong>Total</strong>
          <strong class="text-primary" id="cartTotal">R$ 0,00</strong>
        </div>

        <button class="btn btn-primary w-100 mt-4 py-3" onclick="checkout()">
          <i class="bi bi-credit-card me-2"></i>
          Finalizar Compra
        </button>

      </div>

    </div>

  </div>

  <!-- FOOTER -->
  <footer class="footer-techmode">

    <div class="footer-container">

      <div class="footer-coluna" id="footer-logo-col">
        <img src="/img/logo.png" alt="Logo Renove" class="footer-logo">
        <p class="footer-slogan">Inovação e tecnologia ao seu alcance.</p>
      </div>

      <div class="footer-coluna">
        <h4>Empresa</h4>

        <ul>
          <li><a href="#">Sobre Nós</a></li>
          <li><a href="#">Carreiras</a></li>
          <li><a href="#">Imprensa</a></li>
          <li><a href="#">Contato</a></li>
        </ul>
      </div>

      <div class="footer-coluna">
        <h4>Suporte</h4>

        <ul>
          <li><a href="#">FAQ</a></li>
          <li><a href="#">Central de Ajuda</a></li>
          <li><a href="#">Termos de Serviço</a></li>
          <li><a href="#">Política de Privacidade</a></li>
        </ul>
      </div>

      <div class="footer-coluna">
        <h4>Siga-nos</h4>

        <div class="footer-social-links">

          <a href="#" aria-label="Facebook" title="Facebook">
            <i class="bi bi-facebook"></i>
          </a>

          <a href="#" aria-label="Instagram" title="Instagram">
            <i class="bi bi-instagram"></i>
          </a>

          <a href="#" aria-label="Twitter" title="Twitter">
            <i class="bi bi-twitter-x"></i>
          </a>

        </div>

      </div>

    </div>

    <div class="footer-bottom-bar">
      <p>
        &copy; 2025 Tech Mode. Todos os direitos reservados.
        Desenvolvido por
        <a href="https://luizote1.github.io/tech-mode/" target="_blank" rel="noopener noreferrer">
          Tech Mode
        </a>.
      </p>
    </div>

  </footer>

  <!-- VLIBRAS -->
  <div vw class="enabled">
    <div vw-access-button class="active"></div>

    <div vw-plugin-wrapper>
      <div class="vw-plugin-top-wrapper"></div>
    </div>
  </div>

  <script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>

  <script>
    new window.VLibras.Widget('https://vlibras.gov.br/app');
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/products.js"></script>
  <script src="/js/site.js"></script>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const cartCount = document.getElementById("cartCount");
      const cartCountMobile = document.getElementById("cartCountMobile");

      function sincronizarCarrinhoNavbar() {
        if (cartCount && cartCountMobile) {
          cartCountMobile.textContent = cartCount.textContent;
        }
      }

      sincronizarCarrinhoNavbar();
      setInterval(sincronizarCarrinhoNavbar, 300);
    });
  </script>

  <!-- BOTÃO WHATSAPP -->
  <a href="https://wa.me/5514999999999?text=Olá! Gostaria de agendar um serviço." class="whatsapp-float" target="_blank"
    title="Agendar Serviço">
    <i class="bi bi-whatsapp"></i>
  </a>

  <style>
    .whatsapp-float {
      position: fixed;
      bottom: 25px;
      right: 25px;
      width: 65px;
      height: 65px;
      background: #25D366;
      color: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 34px;
      text-decoration: none;
      box-shadow: 0 8px 25px rgba(37, 211, 102, .4);
      z-index: 100;
      /* menor que o carrinho */
      transition: all .3s ease;
    }

    .whatsapp-float:hover {
      transform: scale(1.1);
      color: #fff;
      text-decoration: none;
      box-shadow: 0 12px 35px rgba(37, 211, 102, .6);
    }

    .whatsapp-float::before {
      content: '';
      position: absolute;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      background: rgba(37, 211, 102, .4);
      animation: pulseWhats 2s infinite;
      z-index: -1;
    }

    .whatsapp-float i {
      line-height: 1;
    }

    @keyframes pulseWhats {
      0% {
        transform: scale(1);
        opacity: .8;
      }

      100% {
        transform: scale(1.8);
        opacity: 0;
      }
    }

    /* RESPONSIVO */
    @media (max-width: 768px) {
      .whatsapp-float {
        width: 58px;
        height: 58px;
        font-size: 30px;
        right: 15px;
        bottom: 15px;
      }
    }
  </style>

</body>

</html>
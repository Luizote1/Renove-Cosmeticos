<script src="/js/promocao/lista.js"></script>

<div>
    <h1>Promoções</h1>

    <a href="/promocao/cadastrar" class="btn btn-primary mb-3">
        <i class="fas fa-plus"></i> Nova Promoção
    </a>

    <div class="card mb-4">
        <div class="card-header">
            <strong>Produtos próximos ao vencimento</strong>
        </div>

        <div class="card-body">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Produto</th>
                        <th>Preço</th>
                        <th>Estoque</th>
                        <th>Validade</th>
                    </tr>
                </thead>

                <tbody>
                    <% for(let i = 0; i < proximosVencimento.length; i++) { %>
                        <tr>
                            <td><%= proximosVencimento[i].pro_codigo %></td>
                            <td><%= proximosVencimento[i].pro_nome %></td>
                            <td>R$ <%= Number(proximosVencimento[i].pro_preco).toFixed(2).replace(".", ",") %></td>
                            <td><%= proximosVencimento[i].pro_estoque %></td>
                            <td><%= proximosVencimento[i].pro_data_validade %></td>
                        </tr>
                    <% } %>

                    <% if(proximosVencimento.length == 0) { %>
                        <tr>
                            <td colspan="5" class="text-center">
                                Nenhum produto próximo ao vencimento.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <strong>Promoções cadastradas</strong>
        </div>

        <div class="card-body">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Produto</th>
                        <th>Preço Original</th>
                        <th>Desconto</th>
                        <th>Preço Final</th>
                        <th>Início</th>
                        <th>Fim</th>
                        <th>Ativo</th>
                        <th>Ações</th>
                    </tr>
                </thead>

                <tbody>
                    <% for(let i = 0; i < lista.length; i++) { %>
                        <tr>
                            <td><%= lista[i].prom_id %></td>
                            <td><%= lista[i].pro_nome %></td>
                            <td>R$ <%= Number(lista[i].pro_preco).toFixed(2).replace(".", ",") %></td>
                            <td><%= Number(lista[i].prom_desconto).toFixed(2).replace(".", ",") %>%</td>

                            <td>
                                R$
                                <%= 
                                    (
                                        Number(lista[i].pro_preco) -
                                        (Number(lista[i].pro_preco) * Number(lista[i].prom_desconto) / 100)
                                    ).toFixed(2).replace(".", ",")
                                %>
                            </td>

                            <td><%= lista[i].prom_data_inicio %></td>
                            <td><%= lista[i].prom_data_fim %></td>

                            <td>
                                <% if(lista[i].prom_ativo == "s") { %>
                                    <span class="badge bg-success">Sim</span>
                                <% } else { %>
                                    <span class="badge bg-secondary">Não</span>
                                <% } %>
                            </td>

                            <td>
                                <a href="/promocao/alterar/<%= lista[i].prom_id %>" class="btn btn-primary">
                                    <i class="fas fa-pen"></i>
                                </a>

                                <button data-id="<%= lista[i].prom_id %>" class="btn btn-danger btnExcluir">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    <% } %>

                    <% if(lista.length == 0) { %>
                        <tr>
                            <td colspan="9" class="text-center">
                                Nenhuma promoção cadastrada.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>